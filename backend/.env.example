# ─── Database (Neon PostgreSQL) ───────────────────────────────
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# ─── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# For Vercel production, set CORS_ORIGIN to the frontend deployment URL
CORS_ORIGIN=http://localhost:3000

# ─── Clerk Auth ──────────────────────────────────────────────
# Both keys required — clerkMiddleware() crashes without publishable key
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Redis (Upstash — optional, falls back to in-memory LRU) ─
REDIS_URL=
